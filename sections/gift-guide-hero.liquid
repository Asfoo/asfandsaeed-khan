{{ 'gift-guide.css' | asset_url | stylesheet_tag }}
<script src="{{ 'gift-guide.js' | asset_url }}" defer="defer"></script>

<section
  class="gg-banner gg-banner--{{ section.id }} color-{{ section.settings.color_scheme }}"
  style="--gg-banner-height-desktop: {{ section.settings.desktop_height }}px; --gg-banner-height-mobile: {{ section.settings.mobile_height }}px;"
>
  <div class="gg-shell">
    <div class="gg-banner__frame">
      <div class="gg-banner__media">
        <picture>
          {%- if section.settings.mobile_image != blank -%}
            <source
              media="(max-width: 749px)"
              srcset="{{ section.settings.mobile_image | image_url: width: 900 }}"
              width="{{ section.settings.mobile_image.width }}"
              height="{{ section.settings.mobile_image.height }}"
            >
          {%- endif -%}

          {%- if section.settings.desktop_image != blank -%}
            <img
              class="gg-banner__image"
              src="{{ section.settings.desktop_image | image_url: width: 2200 }}"
              alt="{{ section.settings.desktop_image.alt | default: section.settings.heading | escape }}"
              width="{{ section.settings.desktop_image.width }}"
              height="{{ section.settings.desktop_image.height }}"
              loading="lazy"
            >
          {%- elsif section.settings.mobile_image != blank -%}
            <img
              class="gg-banner__image"
              src="{{ section.settings.mobile_image | image_url: width: 1200 }}"
              alt="{{ section.settings.mobile_image.alt | default: section.settings.heading | escape }}"
              width="{{ section.settings.mobile_image.width }}"
              height="{{ section.settings.mobile_image.height }}"
              loading="lazy"
            >
          {%- else -%}
            <img
              class="gg-banner__image"
              src="{{ 'banner.jpg' | asset_url }}"
              alt="{{ section.settings.heading | escape }}"
              width="2200"
              height="1200"
              loading="lazy"
            >
          {%- endif -%}
        </picture>
      </div>

      <div class="gg-banner__topbar">
        <div class="gg-banner__brand">{{ section.settings.brand_text }}</div>

        {%- if section.settings.top_message != blank -%}
          <div class="gg-banner__top-message">{{ section.settings.top_message }}</div>
        {%- endif -%}

        {%- if section.settings.top_button_label != blank -%}
          <a class="gg-button gg-button--accent" href="{{ section.settings.top_button_link | default: '#' }}">
            <span>{{ section.settings.top_button_label }}</span>
            <span class="gg-button__arrow" aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>

      <div class="gg-banner__content scroll-trigger animate--slide-in">
        {%- if section.settings.heading != blank -%}
          <h1 class="gg-banner__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="gg-banner__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a class="gg-button gg-button--dark" href="{{ section.settings.cta_link | default: '#' }}">
            <span>{{ section.settings.cta_label }}</span>
            <span class="gg-button__arrow" aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.bottom_strip_text != blank -%}
        <div class="gg-banner__bottom-strip">{{ section.settings.bottom_strip_text }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gift Guide Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 520,
      "max": 980,
      "step": 20,
      "default": 760,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 420,
      "max": 860,
      "step": 20,
      "default": 620,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_message",
      "label": "Top message",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "top_button_label",
      "label": "Top button label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_button_link",
      "label": "Top button link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "bottom_strip_text",
      "label": "Bottom strip text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Hero"
    }
  ]
}
{% endschema %}
